app:
  name: solvify-agent
  version: 0.1.0
  env: development
  mode: release

log:
  level: info
  filename: logs/solvify-agent.log
  max_size: 100
  max_backups: 7
  max_age: 30
  compress: true

agent:
  enable_demo: true

llm:
  provider: mock
  model: mock-knowledge-assistant
  api_key: ""

rag:
  enabled: true

tools:
  enabled: true

server:
  host: ""
  port: 8080
  shutdown_timeout_seconds: 10
